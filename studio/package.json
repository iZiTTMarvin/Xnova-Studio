{
  "name": "xnova-studio",
  "version": "0.7.0-beta.1",
  "private": true,
  "description": "[Deprecated] Legacy Studio directory. Use apps/studio as the only active host.",
  "author": "Xnova Studio Team",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "pnpm --dir ../apps/studio dev",
    "build": "pnpm --dir ../apps/studio build",
    "preview": "pnpm --dir ../apps/studio preview",
    "pack:dir": "pnpm --dir ../apps/studio pack:dir",
    "pack:win": "pnpm --dir ../apps/studio pack:win",
    "typecheck": "pnpm --dir ../apps/studio typecheck",
    "test": "pnpm --dir ../apps/studio test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "libsql": "^0.5.22",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "libsql"
    ]
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
