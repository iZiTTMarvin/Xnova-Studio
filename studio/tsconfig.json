{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@core/*": ["../cli/src/core/*"],
      "@providers/*": ["../cli/src/providers/*"],
      "@tools/*": ["../cli/src/tools/*"],
      "@tools/core/*": ["../cli/src/tools/core/*"],
      "@tools/ext/*": ["../cli/src/tools/ext/*"],
      "@ui/*": ["../cli/src/ui/*"],
      "@platform/*": ["../cli/src/platform/*"],
      "@commands/*": ["../cli/src/commands/*"],
      "@persistence/*": ["../cli/src/persistence/*"],
      "@observability/*": ["../cli/src/observability/*"],
      "@config/*": ["../cli/src/config/*"],
      "@utils/*": ["../cli/src/utils/*"],
      "@mcp/*": ["../cli/src/mcp/*"],
      "@skills/*": ["../cli/src/skills/*"],
      "@plugin": ["../cli/src/plugin/index.ts"],
      "@plugin/*": ["../cli/src/plugin/*"],
      "@hooks": ["../cli/src/hooks/index.ts"],
      "@hooks/*": ["../cli/src/hooks/*"],
      "@file-index": ["../cli/src/file-index/index.ts"],
      "@file-index/*": ["../cli/src/file-index/*"],
      "@server/*": ["../cli/src/server/*"],
      "@memory": ["../cli/src/memory/index.ts"],
      "@memory/*": ["../cli/src/memory/*"]
    },
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
