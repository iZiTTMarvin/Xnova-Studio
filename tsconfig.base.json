{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@xnova/runtime": ["packages/runtime/src/index.ts"],
      "@xnova/runtime/*": ["packages/runtime/src/*"],
      "@xnova/core": ["packages/core/src/index.ts"],
      "@xnova/core/*": ["packages/core/src/*"],
      "@xnova/config": ["packages/config/src/index.ts"],
      "@xnova/config/*": ["packages/config/src/*"],
      "@xnova/providers": ["packages/providers/src/index.ts"],
      "@xnova/providers/*": ["packages/providers/src/*"],
      "@xnova/persistence": ["packages/persistence/src/index.ts"],
      "@xnova/persistence/*": ["packages/persistence/src/*"],
      "@xnova/platform": ["packages/platform/src/index.ts"],
      "@xnova/platform/*": ["packages/platform/src/*"],
      "@xnova/observability": ["packages/observability/src/index.ts"],
      "@xnova/observability/*": ["packages/observability/src/*"],
      "@xnova/tools": ["packages/tools/src/index.ts"],
      "@xnova/tools/*": ["packages/tools/src/*"],
      "@xnova/memory": ["packages/memory/src/index.ts"],
      "@xnova/memory/*": ["packages/memory/src/*"],
      "@xnova/mcp": ["packages/mcp/src/index.ts"],
      "@xnova/mcp/*": ["packages/mcp/src/*"],
      "@xnova/skills": ["packages/skills/src/index.ts"],
      "@xnova/skills/*": ["packages/skills/src/*"],
      "@xnova/plugin": ["packages/plugin/src/index.ts"],
      "@xnova/plugin/*": ["packages/plugin/src/*"],
      "@hooks": ["packages/core/src/hooks/index.ts"],
      "@hooks/*": ["packages/core/src/hooks/*"],
      "@file-index": ["packages/core/src/file-index/index.ts"],
      "@file-index/*": ["packages/core/src/file-index/*"]
    }
  }
}
