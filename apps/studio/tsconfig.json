{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "paths": {
      "@xnova/runtime": ["../../packages/runtime/src/index.ts"],
      "@xnova/runtime/*": ["../../packages/runtime/src/*"],
      "@xnova/core": ["../../packages/core/src/index.ts"],
      "@xnova/core/*": ["../../packages/core/src/*"],
      "@core": ["../../packages/core/src/index.ts"],
      "@core/*": ["../../packages/core/src/*"],
      "@providers": ["../../packages/providers/src/index.ts"],
      "@providers/*": ["../../packages/providers/src/providers/*"],
      "@tools": ["../../packages/tools/src/index.ts"],
      "@tools/*": ["../../packages/tools/src/*"],
      "@platform": ["../../packages/platform/src/index.ts"],
      "@platform/*": ["../../packages/platform/src/platform/*"],
      "@persistence": ["../../packages/persistence/src/index.ts"],
      "@persistence/*": ["../../packages/persistence/src/persistence/*"],
      "@observability": ["../../packages/observability/src/index.ts"],
      "@observability/*": ["../../packages/observability/src/observability/*"],
      "@config": ["../../packages/config/src/index.ts"],
      "@config/*": ["../../packages/config/src/config/*"],
      "@mcp": ["../../packages/mcp/src/index.ts"],
      "@mcp/*": ["../../packages/mcp/src/*"],
      "@skills": ["../../packages/skills/src/index.ts"],
      "@skills/*": ["../../packages/skills/src/*"],
      "@plugin": ["../../packages/plugin/src/index.ts"],
      "@plugin/*": ["../../packages/plugin/src/*"],
      "@hooks": ["../../packages/core/src/hooks/index.ts"],
      "@hooks/*": ["../../packages/core/src/hooks/*"],
      "@file-index": ["../../packages/core/src/file-index/index.ts"],
      "@file-index/*": ["../../packages/core/src/file-index/*"],
      "@memory": ["../../packages/memory/src/index.ts"],
      "@memory/*": ["../../packages/memory/src/*"]
    },
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
