{
  "name": "xnova-cli",
  "version": "0.13.0",
  "description": "开源多模型 AI 编程 CLI 助手 — 支持 Claude/OpenAI/GLM/DeepSeek/Ollama",
  "type": "module",
  "bin": {
    "xnova": "./dist/bin/ccli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1207575273/Xnova-Code.git"
  },
  "homepage": "https://github.com/1207575273/Xnova-Code#readme",
  "author": "iZiTTMarvin",
  "scripts": {
    "dev": "tsx bin/ccli.ts",
    "dev:pipe": "tsx bin/ccli.ts",
    "dev:web": "node scripts/ensure-web.cjs && tsx bin/ccli.ts --web",
    "build": "tsup",
    "build:web": "node scripts/ensure-web.cjs && cd web && pnpm build",
    "build:all": "tsup && node scripts/ensure-web.cjs && cd web && pnpm build",
    "test": "vitest run",
    "test:baseline": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "cli",
    "llm",
    "agent",
    "claude",
    "openai",
    "glm",
    "deepseek",
    "coding-assistant",
    "mcp",
    "multi-model"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.30",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/openai": "^1.2.12",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "diff": "^8.0.3",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fzf": "^0.5.2",
    "hono": "^4.12.5",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "ink-multiline-input": "^0.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jieba-wasm": "^2.4.0",
    "libsql": "^0.5.22",
    "marked": "^17.0.4",
    "react": "^19.2.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
