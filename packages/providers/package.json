{
  "name": "@xnova/providers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova Provider 适配领域包",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/providers/tsconfig.json",
    "test": "pnpm -w exec vitest run --config packages/providers/vitest.config.ts"
  },
  "dependencies": {
    "@xnova/config": "workspace:*",
    "@xnova/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.40.1",
    "@langchain/core": "^0.3.79",
    "@langchain/openai": "^0.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
