{
  "name": "@xnova/config",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova 基础配置领域包",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/config/tsconfig.json",
    "test": "pnpm -w exec vitest run --config packages/config/vitest.config.ts"
  },
  "dependencies": {
    "@xnova/providers": "workspace:*",
    "@xnova/tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
