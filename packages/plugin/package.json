{
  "name": "@xnova/plugin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova 能力域：Runtime Plugin 最小能力",
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/plugin/tsconfig.json",
    "test": "pnpm -w exec vitest run --config packages/plugin/vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "dependencies": {
    "@xnova/core": "workspace:*",
    "@xnova/tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5"
  }
}
