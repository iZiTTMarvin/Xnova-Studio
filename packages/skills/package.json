{
  "name": "@xnova/skills",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova 能力域：Skills 发现与调用",
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/skills/tsconfig.json",
    "test": "pnpm -w exec vitest run --config packages/skills/vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "dependencies": {
    "@xnova/tools": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5"
  }
}