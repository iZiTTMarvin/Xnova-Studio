{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@xnova/core": ["src/index.ts"],
      "@xnova/core/*": ["src/*"],
      "@core": ["src/index.ts"],
      "@core/*": ["src/*"],
      "@core/*.js": ["src/*.ts"],
      "@providers/*": ["../../packages/providers/src/providers/*"],
      "@tools": ["../../packages/tools/src/index.ts"],
      "@tools/*": ["../../packages/tools/src/*"],
      "@hooks": ["src/hooks/index.ts"],
      "@hooks/*": ["src/hooks/*"],
      "@config/*": ["../../packages/config/src/config/*"],
      "@mcp": ["../../packages/mcp/src/index.ts"],
      "@mcp/*": ["../../packages/mcp/src/*"],
      "@observability/*": ["../../packages/observability/src/observability/*"],
      "@persistence/*": ["../../packages/persistence/src/persistence/*"],
      "@skills": ["../../packages/skills/src/index.ts"],
      "@skills/*": ["../../packages/skills/src/*"],
      "@file-index": ["src/file-index/index.ts"],
      "@file-index/*": ["src/file-index/*"],
      "@plugin": ["../../packages/plugin/src/index.ts"],
      "@plugin/*": ["../../packages/plugin/src/*"],
      "@memory": ["../../packages/memory/src/index.ts"],
      "@memory/*": ["../../packages/memory/src/*"],
      "@platform/*": ["../../packages/platform/src/platform/*"]
    },
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
