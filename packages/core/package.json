{
  "name": "@xnova/core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova 共享运行时内核编排层",
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/core/tsconfig.json",
