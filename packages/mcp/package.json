{
  "name": "@xnova/mcp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Xnova 能力域：MCP 管理与工具桥接",
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "pnpm -w exec tsc --noEmit -p packages/mcp/tsconfig.json",
    "test": "pnpm -w exec vitest run --config packages/mcp/vitest.config.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@xnova/tools": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5"
  }
}